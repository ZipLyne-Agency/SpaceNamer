<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Hardened runtime blocks Apple Events without this — no consent
	     prompt, no Automation pane entry, just silent -1743. Needed for
	     reading browser tab URLs on workspace save/restore. -->
	<key>com.apple.security.automation.apple-events</key>
	<true/>
</dict>
</plist>
